# --- 构建产物 ---
firmware/.pio/
experiments/**/.pio/
fw/                               # OTA 产物(current.bin / version.txt)

# --- Python ---
__pycache__/
**/__pycache__/
*.pyc

# --- 打包 / 临时 ---
*.tgz
*.log
.DS_Store

